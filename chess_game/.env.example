# ── Chess Game Server — Environment Variables ──────────────────────────────────
# Copy this file to .env or set these in your deployment environment.

# Database
DB_DRIVER=postgres
DB_URL=postgresql://chess:your-db-password@localhost:5432/chess_game?sslmode=disable

# Server
SERVER_ADDRESS=0.0.0.0:8080
ENVIRONMENT=production

# Token (generate with: openssl rand -hex 64)
ACCESS_TOKEN_DURATION=15m
TokenSymmetricKey=change-me-to-a-random-64-char-hex-string

# Email (Resend API key for OTP emails)
RESEND_API_KEY=re_your_resend_api_key_here
